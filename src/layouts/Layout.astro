---
// src/layouts/Layout.astro
import '../styles/global.css';
export interface Props {
  title?: string;
  description?: string;
}
const { title = 'Fencing Analytics', description = 'Alberta fencing tournament analytics platform' } = Astro.props;

const navItems = [
  { href: '/',            label: 'Dashboard',     icon: '<rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/>' },
  { href: '/rankings',    label: 'Rankings',      icon: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>' },
  { href: '/elo',         label: 'ELO Ratings',   icon: '<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>' },
  { href: '/clubs',       label: 'Clubs',         icon: '<circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>' },
  { href: '/tournaments', label: 'Tournaments',   icon: '<path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>' },
  { href: '/fencer',      label: 'Fencer Search', icon: '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>' },
  { href: '/h2h',         label: 'Head-to-Head',  icon: '<polyline points="14.5 17.5 3 6 3 3 6 3 17.5 14.5"/><line x1="13" x2="19" y1="19" y2="13"/><line x1="16" x2="20" y1="16" y2="20"/><line x1="19" x2="21" y1="21" y2="19"/><polyline points="14.5 6.5 18 3 21 3 21 6 17.5 9.5"/><line x1="5" x2="9" y1="14" y2="18"/><line x1="7" x2="4" y1="17" y2="20"/><line x1="3" x2="5" y1="19" y2="21"/>' },
];

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — AFA Analytics</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>

  <body class="min-h-screen bg-background text-foreground flex">

    <!-- ── Sidebar ─────────────────────────────────────────── -->
    <aside id="sidebar" class="sidebar-shell hidden lg:flex flex-col w-56 shrink-0 border-r border-sidebar-border bg-sidebar-background min-h-screen sticky top-0 h-screen overflow-y-auto z-30">

      <!-- Logo -->
      <div class="flex items-center gap-3 px-5 py-5 border-b border-sidebar-border">
        <div class="w-8 h-8 rounded-lg bg-sidebar-primary/20 border border-sidebar-primary/30 flex items-center justify-center shrink-0">
          <svg class="w-4 h-4 text-sidebar-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="14.5 17.5 3 6 3 3 6 3 17.5 14.5"/>
            <line x1="13" x2="19" y1="19" y2="13"/>
            <line x1="16" x2="20" y1="16" y2="20"/>
            <line x1="19" x2="21" y1="21" y2="19"/>
          </svg>
        </div>
        <div>
          <div class="text-sm font-bold text-sidebar-accent-foreground tracking-tight leading-none">AFA</div>
          <div class="text-[10px] text-sidebar-foreground font-mono tracking-widest uppercase mt-0.5 opacity-60">Analytics</div>
        </div>
      </div>

      <!-- Nav -->
      <nav class="flex flex-col gap-0.5 px-3 py-4 flex-1">
        <p class="px-2 pb-1.5 text-[9px] font-semibold text-sidebar-foreground/40 uppercase tracking-[.12em]">Main</p>
        {navItems.slice(0, 5).map(item => {
          const active = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
          return (
            <a
              href={item.href}
              class={`flex items-center gap-3 px-3 py-2 rounded-lg text-xs font-medium transition-all duration-150 group
                ${active
                  ? 'bg-sidebar-primary/15 text-sidebar-primary border-r-[2px] border-sidebar-primary rounded-r-none -mr-3 pr-[calc(0.75rem+2px)]'
                  : 'text-sidebar-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground'
                }`}
            >
              <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <Fragment set:html={item.icon} />
              </svg>
              {item.label}
            </a>
          );
        })}

        <p class="px-2 pt-4 pb-1.5 text-[9px] font-semibold text-sidebar-foreground/40 uppercase tracking-[.12em]">Tools</p>
        {navItems.slice(5).map(item => {
          const active = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
          return (
            <a
              href={item.href}
              class={`flex items-center gap-3 px-3 py-2 rounded-lg text-xs font-medium transition-all duration-150 group
                ${active
                  ? 'bg-sidebar-primary/15 text-sidebar-primary border-r-[2px] border-sidebar-primary rounded-r-none -mr-3 pr-[calc(0.75rem+2px)]'
                  : 'text-sidebar-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground'
                }`}
            >
              <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <Fragment set:html={item.icon} />
              </svg>
              {item.label}
            </a>
          );
        })}
      </nav>

      <!-- Footer -->
      <div class="px-5 py-4 border-t border-sidebar-border">
        <p class="text-[10px] font-mono text-sidebar-foreground/40 leading-relaxed">
          Alberta Fencing<br/>Association © 2024
        </p>
      </div>
    </aside>

    <!-- ── Right side: topbar + page ──────────────────────── -->
    <div class="flex flex-col flex-1 min-w-0">

      <!-- Topbar (mobile + desktop) -->
      <header class="sticky top-0 z-20 flex items-center gap-3 h-14 px-4 sm:px-6 border-b border-border bg-background/80 backdrop-blur-xl supports-[backdrop-filter]:bg-background/60">

        <!-- Mobile hamburger -->
        <button id="mobile-menu-btn" class="lg:hidden p-1.5 rounded-lg hover:bg-accent transition-colors text-muted-foreground shrink-0">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>

        <!-- Breadcrumb / page title -->
        <div class="flex items-center gap-2 text-sm min-w-0 flex-1">
          <span class="font-semibold text-foreground truncate">{title}</span>
          <span class="text-muted-foreground/40 hidden sm:inline">·</span>
          <span class="font-mono text-[11px] text-muted-foreground hidden sm:inline truncate">AFA Analytics</span>
        </div>

        <!-- Desktop nav links (compact, shown only when sidebar is hidden) -->
        <nav class="hidden lg:hidden items-center gap-0.5">
          {navItems.slice(0,5).map(item => (
            <a href={item.href} class="px-2.5 py-1.5 rounded-lg text-xs font-medium text-muted-foreground hover:text-foreground hover:bg-accent transition-colors">
              {item.label}
            </a>
          ))}
        </nav>
      </header>

      <!-- Mobile slide-out menu -->
      <div id="mobile-menu" class="hidden lg:hidden fixed inset-0 z-40" aria-hidden="true">
        <div id="mobile-overlay" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
        <aside class="absolute left-0 top-0 h-full w-64 bg-sidebar-background border-r border-sidebar-border flex flex-col overflow-y-auto">
          <div class="flex items-center justify-between px-5 py-5 border-b border-sidebar-border">
            <div class="flex items-center gap-3">
              <div class="w-7 h-7 rounded-lg bg-sidebar-primary/20 border border-sidebar-primary/30 flex items-center justify-center">
                <svg class="w-3.5 h-3.5 text-sidebar-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="14.5 17.5 3 6 3 3 6 3 17.5 14.5"/>
                  <line x1="13" x2="19" y1="19" y2="13"/>
                  <line x1="16" x2="20" y1="16" y2="20"/>
                  <line x1="19" x2="21" y1="21" y2="19"/>
                </svg>
              </div>
              <span class="text-sm font-bold text-sidebar-accent-foreground">AFA Analytics</span>
            </div>
            <button id="mobile-close" class="p-1.5 rounded-lg text-sidebar-foreground hover:bg-sidebar-accent transition-colors">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
          <nav class="flex flex-col gap-0.5 px-3 py-4">
            <p class="px-2 pb-1.5 text-[9px] font-semibold text-sidebar-foreground/40 uppercase tracking-[.12em]">Main</p>
            {navItems.slice(0, 5).map(item => (
              <a href={item.href} class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-sidebar-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground transition-colors">
                <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <Fragment set:html={item.icon} />
                </svg>
                {item.label}
              </a>
            ))}
            <p class="px-2 pt-4 pb-1.5 text-[9px] font-semibold text-sidebar-foreground/40 uppercase tracking-[.12em]">Tools</p>
            {navItems.slice(5).map(item => (
              <a href={item.href} class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-sidebar-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground transition-colors">
                <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <Fragment set:html={item.icon} />
                </svg>
                {item.label}
              </a>
            ))}
          </nav>
        </aside>
      </div>

      <!-- Page content -->
      <main class="flex-1 px-4 sm:px-6 lg:px-8 py-7 max-w-6xl w-full mx-auto lg:mx-0 lg:max-w-none">
        <slot />
      </main>

      <footer class="px-6 py-4 border-t border-border flex items-center justify-between">
        <p class="font-mono text-[10px] text-muted-foreground/50 tracking-wide">
          AFA Analytics · Alberta Fencing Association Data Platform
        </p>
        <p class="font-mono text-[10px] text-muted-foreground/30">v2024</p>
      </footer>
    </div>

  </body>
</html>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const overlay = document.getElementById('mobile-overlay');
  const closeBtn = document.getElementById('mobile-close');

  function openMenu() {
    menu?.classList.remove('hidden');
    menu?.removeAttribute('aria-hidden');
    document.body.style.overflow = 'hidden';
  }
  function closeMenu() {
    menu?.classList.add('hidden');
    menu?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  btn?.addEventListener('click', openMenu);
  overlay?.addEventListener('click', closeMenu);
  closeBtn?.addEventListener('click', closeMenu);
</script>