---
// src/pages/rankings.astro
import Layout from '../layouts/Layout.astro';
import { getRankings, getFilterOptions } from '../lib/queries';
import { formatPoints } from '../lib/format';

const url = Astro.url;
const season   = url.searchParams.get('season')   ?? '';
const weapon   = url.searchParams.get('weapon')   ?? '';
const sex      = url.searchParams.get('sex')      ?? '';
const category = url.searchParams.get('category') ?? '';

// Users must select Season, Weapon, and Category to see results
const hasRequiredFilters = season && weapon && category;

let rankings: any[] = [];
let filterOpts = { seasons: [] as string[], weapons: [] as string[], categories: [] as string[] };

try {
  const queries: any[] = [getFilterOptions()];
  
  // Only fetch rankings if the required filters are actually applied
  if (hasRequiredFilters) {
    queries.push(
      getRankings({ 
        season, 
        weapon, 
        sex: sex || undefined, 
        category, 
        limit: 50 
      })
    );
  }

  const results = await Promise.all(queries);
  filterOpts = results[0];
  
  if (hasRequiredFilters) {
    rankings = results[1];
  }
} catch {}

const SEX_OPTIONS = ['Men', 'Women', 'Mixed', 'Wheelchair'];
---

<Layout title="Rankings">
  <div class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight text-foreground mb-1">Rankings</h1>
    <p class="text-muted-foreground">Points by season, weapon, and category</p>
  </div>

  <!-- Filters -->
  <form method="get" class="card p-4 mb-6 flex flex-wrap gap-3 items-end">
    <div class="flex-1 min-w-[140px]">
      <label class="block text-xs text-muted-foreground mb-1.5 uppercase tracking-wide font-medium">
        Season <span class="text-red-500">*</span>
      </label>
      <select name="season" class="select" required>
        <option value="" disabled={!season}>Select Season</option>
        {filterOpts.seasons.map(s => <option value={s} selected={s === season}>{s}</option>)}
      </select>
    </div>
    <div class="flex-1 min-w-[130px]">
      <label class="block text-xs text-muted-foreground mb-1.5 uppercase tracking-wide font-medium">
        Weapon <span class="text-red-500">*</span>
      </label>
      <select name="weapon" class="select" required>
        <option value="" disabled={!weapon}>Select Weapon</option>
        {filterOpts.weapons.map(w => <option value={w} selected={w === weapon}>{w}</option>)}
      </select>
    </div>
    <div class="flex-1 min-w-[130px]">
      <label class="block text-xs text-muted-foreground mb-1.5 uppercase tracking-wide font-medium">Sex</label>
      <select name="sex" class="select">
        <option value="">All</option>
        {SEX_OPTIONS.map(s => <option value={s} selected={s === sex}>{s}</option>)}
      </select>
    </div>
    <div class="flex-1 min-w-[140px]">
      <label class="block text-xs text-muted-foreground mb-1.5 uppercase tracking-wide font-medium">
        Category <span class="text-red-500">*</span>
      </label>
      <select name="category" class="select" required>
        <option value="" disabled={!category}>Select Category</option>
        {filterOpts.categories.map(c => <option value={c} selected={c === category}>{c}</option>)}
      </select>
    </div>
    <button type="submit" class="btn-primary shrink-0">Apply</button>
    <a href="/rankings" class="btn-secondary shrink-0">Reset</a>
  </form>

  <!-- Table -->
  <div class="card overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border bg-muted/50">
            <th class="px-4 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wide w-12">#</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wide">Fencer</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wide hidden sm:table-cell">Club</th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-muted-foreground uppercase tracking-wide hidden md:table-cell">Tournaments</th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-muted-foreground uppercase tracking-wide">Points</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border">
          {rankings.length === 0 ? (
            <tr>
              <td colspan="5" class="px-4 py-12 text-center text-slate-500">
                {!hasRequiredFilters
                  ? 'Please select a Season, Weapon, and Category to view rankings.'
                  : 'No results found for the selected filters.'}
              </td>
            </tr>
          ) : rankings.map(r => (
              <tr class="table-row-hover">
                <td class="px-4 py-3">
                  <span class={"font-bold tabular-nums text-sm " + (
                    r.rank === 1 ? 'text-yellow-500 dark:text-yellow-400' :
                    r.rank === 2 ? 'text-slate-400' :
                    r.rank === 3 ? 'text-orange-500 dark:text-orange-400' :
                    'text-muted-foreground'
                  )}>
                    {r.rank <= 3 ? ['🥇','🥈','🥉'][r.rank-1] : '#' + r.rank}
                  </span>
                </td>
                <td class="px-4 py-3">
                  <a href={'/fencer/' + r.member?.id} class="font-semibold hover:text-primary transition-colors text-foreground">
                    {r.member?.fullName ?? '—'}
                  </a>
                </td>
                <td class="px-4 py-3 text-muted-foreground hidden sm:table-cell text-xs">{r.member?.club ?? '—'}</td>
                <td class="px-4 py-3 text-right text-muted-foreground hidden md:table-cell tabular-nums">{r.tournaments}</td>
                <td class="px-4 py-3 text-right font-mono font-bold text-foreground tabular-nums">
                  {formatPoints(r.totalPoints ?? 0)}
                </td>
              </tr>
            ))}
        </tbody>
      </table>
    </div>
  </div>
</Layout>