---
// src/pages/index.astro  (landing page = AFA Rankings)
import Layout from '../layouts/Layout.astro';
import { getRankingsAFA, getFilterOptions } from '../lib/queries';
import { formatPoints } from '../lib/format';

const url = Astro.url;

// Pre-load filter options first so we can set sensible defaults
const filterOpts = await getFilterOptions().catch(() => ({
  seasons:    [] as string[],
  weapons:    [] as string[],
  categories: [] as string[],
}));

const defaultSeason   = filterOpts.seasons[0]   ?? '';
const defaultWeapon   = filterOpts.weapons.includes('Saber')  ? 'Saber'  : (filterOpts.weapons[0]  ?? '');
const defaultCategory = filterOpts.categories.includes('Senior') ? 'Senior' : (filterOpts.categories[0] ?? '');
const defaultSex      = 'Women';

const season   = url.searchParams.get('season')   ?? defaultSeason;
const weapon   = url.searchParams.get('weapon')   ?? defaultWeapon;
// "Any" means fold Men + Women + Mixed points together per fencer.
// "Men" means fold Mixed event points into Men totals.
// "Women" means only Women's event points.
const sex      = url.searchParams.get('sex')      ?? defaultSex;
const category = url.searchParams.get('category') ?? defaultCategory;

const hasRequiredFilters = !!(season && weapon && category);

let rankings: any[] = [];
try {
  if (hasRequiredFilters) {
    rankings = await getRankingsAFA({ season, weapon, sex: sex || undefined, category, limit: 100 });
  }
} catch {}

const SEX_OPTIONS = ['Men', 'Women', 'Any'];
---

<Layout title="Rankings">
  <div class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight text-foreground mb-1">AFA Rankings</h1>
    <p class="text-muted-foreground">Alberta Fencing Association member rankings by season, weapon, and category</p>
  </div>

  <!-- Filters — auto-apply on change, no need to hit Apply -->
  <form id="rankingsForm" method="get" class="card p-4 mb-6 flex flex-wrap gap-3 items-end">
    <div class="flex-1 min-w-[140px]">
      <label class="block text-xs text-muted-foreground mb-1.5 uppercase tracking-wide font-medium">Season</label>
      <select name="season" id="f-season" class="select">
        {filterOpts.seasons.map(s => <option value={s} selected={s === season}>{s}</option>)}
      </select>
    </div>
    <div class="flex-1 min-w-[130px]">
      <label class="block text-xs text-muted-foreground mb-1.5 uppercase tracking-wide font-medium">Weapon</label>
      <select name="weapon" id="f-weapon" class="select">
        {filterOpts.weapons.map(w => <option value={w} selected={w === weapon}>{w}</option>)}
      </select>
    </div>
    <div class="flex-1 min-w-[130px]">
      <label class="block text-xs text-muted-foreground mb-1.5 uppercase tracking-wide font-medium">Sex</label>
      <select name="sex" id="f-sex" class="select">
        {SEX_OPTIONS.map(s => <option value={s} selected={s === sex}>{s}</option>)}
      </select>
    </div>
    <div class="flex-1 min-w-[140px]">
      <label class="block text-xs text-muted-foreground mb-1.5 uppercase tracking-wide font-medium">Category</label>
      <select name="category" id="f-category" class="select">
        {filterOpts.categories.map(c => <option value={c} selected={c === category}>{c}</option>)}
      </select>
    </div>
    <button type="submit" class="btn-primary shrink-0">Apply</button>
    <a href="/" class="btn-secondary shrink-0">Reset</a>
  </form>

  <!-- Results table -->
  <div class="card overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border bg-muted/50">
            <th class="px-4 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wide w-12">#</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wide">Fencer</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wide hidden sm:table-cell">Club</th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-muted-foreground uppercase tracking-wide hidden md:table-cell">Tournaments</th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-muted-foreground uppercase tracking-wide">Points</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border">
          {rankings.length === 0 ? (
            <tr>
              <td colspan="5" class="px-4 py-12 text-center text-slate-500">
                {!hasRequiredFilters
                  ? 'Select a Season, Weapon, and Category to view rankings.'
                  : 'No AFA member results found for the selected filters.'}
              </td>
            </tr>
          ) : rankings.map(r => (
            <tr class="table-row-hover">
              <td class="px-4 py-3">
                <span class={"font-bold tabular-nums text-sm " + (
                  r.rank === 1 ? 'text-yellow-500 dark:text-yellow-400' :
                  r.rank === 2 ? 'text-slate-400' :
                  r.rank === 3 ? 'text-orange-500 dark:text-orange-400' :
                  'text-muted-foreground'
                )}>
                  {r.rank <= 3 ? ['🥇','🥈','🥉'][r.rank-1] : '#' + r.rank}
                </span>
              </td>
              <td class="px-4 py-3">
                <a href={'/fencer/' + r.member?.id} class="font-semibold hover:text-primary transition-colors text-foreground">
                  {r.member?.fullName ?? '—'}
                </a>
              </td>
              <td class="px-4 py-3 text-muted-foreground hidden sm:table-cell text-xs">{r.member?.club ?? '—'}</td>
              <td class="px-4 py-3 text-right text-muted-foreground hidden md:table-cell tabular-nums">{r.tournaments}</td>
              <td class="px-4 py-3 text-right font-mono font-bold text-foreground tabular-nums">
                {formatPoints(r.totalPoints ?? 0)}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</Layout>

<script>
  // Auto-submit rankings form when any filter changes (no Apply click needed)
  const form = document.getElementById('rankingsForm') as HTMLFormElement | null;
  if (form) {
    ['f-season', 'f-weapon', 'f-sex', 'f-category'].forEach(id => {
      document.getElementById(id)?.addEventListener('change', () => form.submit());
    });
  }

  // Persist filter state to localStorage so ELO / other pages can pre-sync
  const params = new URLSearchParams(window.location.search);
  const updates: Record<string, string> = {};
  ['season', 'weapon', 'sex', 'category'].forEach(k => {
    const v = params.get(k);
    if (v) updates[k] = v;
  });
  if (Object.keys(updates).length) {
    const stored = JSON.parse(localStorage.getItem('afa-filters') || '{}');
    localStorage.setItem('afa-filters', JSON.stringify({ ...stored, ...updates }));
  }
</script>
